ec2:
aws ec2 create-security-group --group-name my-open-sg --description "Security group with open access"

aws ec2 authorize-security-group-ingress --group-name my-open-sg --protocol -1 --port -1 --cidr 0.0.0.0/0

aws ec2 describe-images --owners amazon \
  --filters "Name=name,Values=amzn2-ami-hvm-*-x86_64-gp2" \
            "Name=state,Values=available" \
  --query "sort_by(Images, &CreationDate)[-1].ImageId" \
  --output text


aws ec2 run-instances --image-id ami-040855b0715ee6f0b --instance-type t3.micro --security-groups my-open-sg --count 1 --tag-specifications 'ResourceType=instance,Tags=[{Key=Name,Value=my-free-tier-vm}]'


S3:

aws s3api create-bucket --bucket bsidestestcmd --region us-east-1

aws s3api create-bucket --bucket bsidestestcmd --region us-west-2 --create-bucket-configuration LocationConstraint=us-west-2

disable blockpublicpolicy
aws s3api put-public-access-block --bucket bsidestestcmd --public-access-block-configuration "BlockPublicAcls=false,IgnorePublicAcls=false,BlockPublicPolicy=false,RestrictPublicBuckets=false"

create bucketpolicy.json
attach it
aws s3api put-bucket-policy --bucket bsidestestcmd --policy '{"Version":"2012-10-17","Statement":[{"Sid":"PublicReadGetObject","Effect":"Allow","Principal":"*","Action":"s3:GetObject","Resource":"arn:aws:s3:::bsidestestcmd/*"}]}'

password policy:
aws iam update-account-password-policy --minimum-password-length 6
